# D.Run Pitstop 环境变量配置
# 复制此文件为 .env 并修改

# OIDC 认证 (Ghippo/Keycloak)
OIDC_ISSUER_URL=https://console.d.run/auth/realms/ghippo
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret
OIDC_REDIRECT_URI=http://localhost:3001/api/v1/auth/callback

# 用户 Token 有效期（小时），默认 1
USER_TOKEN_TTL_HOURS=1

# Session 有效期（小时），默认 24
SESSION_TTL_HOURS=24

## Branding (optional)
# APP_NAME=Pitstop
# APP_BRAND=D.Run